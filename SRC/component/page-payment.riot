  <script>
    import pageLayout from './page-layout.riot';
    import { debounce } from '../helper.common.mjs';

    const LOCAL_STORAGE_KEY = 'PaymentData';

    export default {
      autoSave: () => {},

      components: {
        itemList,
        monthPicker,
        pageLayout,
        total,
      },

      state: {
        months: [],
      //   HsTrnsfrCnfrm,
      //   IsTrnsfrOt,
      //   TrnsfrLnk,
      },

      onBeforeMount (props, state) {
        // state.HsTrnsfrCnfrm = props.TrnsfrData ? true : false; // has transfering confirmation.
        // state.IsTrnsfrOt = false; // is transfer out.
        // state.TrnsfrLnk = ''; // transfer link.
      },

      onMounted (props, state) {
        if (this.OnBrowser()) {
          const autoSave = debounce((items = []) => {
            setTimeout(
              () => { window.localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(items)); },
              1000);
          })

          this.StoreListen(
            'PAYMENT',
            items => { autoSave(items); },
            false);

          this.dataFromJSON(window.localStorage.getItem(LOCAL_STORAGE_KEY));
        }

        // this.StoreListen(
        //   'TRANSFER',
        //   (Sto, TskPrms) => {
        //     this.update({ TrnsfrLnk: Sto ? (window.location.origin + '/payment?t=' + Sto) : 'can not transer data.' });
        //   });
      },

      /* set up data from JSON string.
        @ JSON string.
        < result code number. */
      dataFromJSON (str) {
        let data;

        try {
          data = str ? JSON.parse(str) : [];
        }
        catch (error) {
          alert(error);

          return -1;
        }

        if (!Array.isArray(data)) {
          data = [];
        }

        this.StoreSet('PAYMENT', () => data);
      },

      // Transfer (Evt) {
      //   this.ServiceCall(
      //     '/service/transfer',
      //     { Ctn: window.localStorage.PaymentData },
      //     'TRANSFER',
      //     (Sto, Rst) => { return Rst; });

      //   this.TransferModeToggle(Evt);
      // },

      // TransferModeToggle (Evt) {
      //   this.IsTrnsfrOt = !this.IsTrnsfrOt;
      // },

      // TransferIgnore (Evt) {
      //   this.HsTrnsfrCnfrm = false;
      // },

      // TransferReplace (Evt) {
      //   this.dataFromJSON(this.props.TrnsfrData);
      //   this.autoSave({ HsTrnsfrCnfrm: false });
