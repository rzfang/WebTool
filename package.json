{
  "name": "web_tool",
  "version": "0.3.6",
  "description": "web tool",
  "main": "webtool.mjs",
  "dependencies": {
    "feedparser": "^2.2.9",
    "json5": "^2.2.3",
    "request": "^2.88.2",
    "riot-4-fun": "^0.3.10",
    "rzjs": "github:rzfang/Js"
  },
  "devDependencies": {
    "@eslint/css": "^1",
    "@fastify/pre-commit": "^2",
    "eslint": "^10",
    "globals": "^17",
    "nodemon": "^3"
  },
  "scripts": {
    "build": "r4f build",
    "dev": "nodemon -x 'r4f dev' -e abc -w r4f.config.mjs -w SRC/service",
    "dev:ws": "nodemon -d 3 -w SRC/websocket.mjs SRC/websocket.mjs",
    "lint": "eslint",
    "start": "r4f start",
    "start:pm2": "pm2 start --name webtool npm -- run start",
    "start:ws": "node SRC/websocket.mjs",
    "start:ws:pm2": "pm2 start --name websocket npm -- run start:ws",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rzfang/WebTool.git"
  },
  "keywords": [
    "web",
    "tool"
  ],
  "author": "RZ Fang",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rzfang/WebTool/issues"
  },
  "homepage": "https://github.com/rzfang/WebTool#readme",
  "pre-commit": [
    "lint"
  ]
}
